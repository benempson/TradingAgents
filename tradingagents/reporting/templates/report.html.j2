<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Trading Analysis Report: {{ report.ticker }}</title>
  <style>
    /* ── reset & base ─────────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; }
    body {
      max-width: 900px;
      margin: 0 auto;
      padding: 1rem;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
                   "Helvetica Neue", Arial, sans-serif;
      line-height: 1.6;
      color: #1a1a1a;
      background: #fafafa;
      overflow-wrap: break-word;
    }

    /* ── headings ─────────────────────────────────────────────────────── */
    h1 {
      font-size: 1.75rem;
      margin-bottom: 0.25rem;
      color: #111;
    }
    h2 {
      font-size: 1.35rem;
      margin-top: 2rem;
      padding-bottom: 0.3rem;
      border-bottom: 2px solid #e5e7eb;
      color: #1f2937;
    }
    h3 {
      font-size: 1.1rem;
      margin-top: 1.25rem;
      padding-bottom: 0.2rem;
      border-bottom: 1px solid #e5e7eb;
      color: #374151;
    }

    /* ── signal badge ─────────────────────────────────────────────────── */
    .signal-badge {
      display: inline-block;
      padding: 0.3rem 0.9rem;
      border-radius: 0.375rem;
      font-weight: 700;
      font-size: 0.95rem;
      letter-spacing: 0.03em;
      text-transform: uppercase;
      vertical-align: middle;
    }
    .signal-buy        { background: #22c55e; color: #fff; }
    .signal-overweight  { background: #86efac; color: #14532d; }
    .signal-hold       { background: #fbbf24; color: #78350f; }
    .signal-underweight { background: #fb923c; color: #7c2d12; }
    .signal-sell       { background: #ef4444; color: #fff; }

    /* ── header meta ──────────────────────────────────────────────────── */
    .header-meta {
      color: #6b7280;
      font-size: 0.9rem;
      margin-top: 0.5rem;
    }
    hr {
      border: none;
      border-top: 1px solid #d1d5db;
      margin: 1.5rem 0;
    }

    /* ── details / transcript ─────────────────────────────────────────── */
    details {
      border: 1px solid #e5e7eb;
      border-radius: 0.5rem;
      padding: 0;
      margin-bottom: 1rem;
      background: #fff;
    }
    summary {
      cursor: pointer;
      font-weight: 600;
      padding: 0.6rem 1rem;
      background: #f9fafb;
      border-radius: 0.5rem;
      user-select: none;
    }
    summary:hover { background: #f3f4f6; }
    details[open] summary {
      border-bottom: 1px solid #e5e7eb;
      border-radius: 0.5rem 0.5rem 0 0;
    }
    .transcript {
      padding: 0.75rem 1rem;
      white-space: pre-wrap;
      font-size: 0.88rem;
      line-height: 1.55;
      color: #374151;
    }
    .collapse-link {
      display: block;
      padding: 0.4rem 1rem 0.6rem;
      text-align: right;
      font-size: 0.82rem;
      color: #6b7280;
      cursor: pointer;
      user-select: none;
      border-top: 1px solid #f3f4f6;
    }
    .collapse-link:hover { color: #374151; }

    /* ── section summary text ─────────────────────────────────────────── */
    .section-summary {
      margin: 0.5rem 0 0.75rem 0;
      color: #374151;
    }

    /* ── not included ─────────────────────────────────────────────────── */
    .not-included {
      font-style: italic;
      color: #9ca3af;
    }

    /* ── print ────────────────────────────────────────────────────────── */
    @media print {
      body { background: #fff; max-width: 100%; padding: 0; }
      details { border: 1px solid #ccc; }
      details[open] > summary { display: none; }
      details > .transcript { display: block !important; }
      .signal-badge { print-color-adjust: exact; -webkit-print-color-adjust: exact; }
    }

    /* ── mobile ───────────────────────────────────────────────────────── */
    @media (max-width: 640px) {
      body { padding: 0.5rem; font-size: 0.95rem; }
      h1 { font-size: 1.4rem; }
      h2 { font-size: 1.15rem; }
      h3 { font-size: 1rem; }
    }
  </style>
  <script>
    function collapseAndScroll(el) {
      var details = el.parentElement;
      details.removeAttribute('open');
      details.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  </script>
</head>
<body>

  {# ── Reusable macro for rendering a report section ────────────────── #}
  {% macro render_section(section) %}
    {% if section.included %}
      {% if section.summary %}
        <p class="section-summary">{{ section.summary }}</p>
      {% endif %}
      <details>
        <summary>View full transcript</summary>
        <div class="transcript">{{ section.content | e }}</div>
        <span class="collapse-link" onclick="collapseAndScroll(this)">Collapse full transcript</span>
      </details>
    {% else %}
      <p class="not-included">Not included in this analysis run.</p>
    {% endif %}
  {% endmacro %}

  {# ── Header ───────────────────────────────────────────────────────── #}
  <header>
    <h1>Trading Analysis Report: {{ report.ticker }}
      <span class="signal-badge {{ signal_class }}">{{ report.final_signal }}</span>
    </h1>
    <p class="header-meta">
      Trade date: {{ report.trade_date }}<br>
      Generated: {{ report.generated_at }}
    </p>
  </header>

  {% if report.final_decision_full %}
  <details>
    <summary>View full decision rationale</summary>
    <div class="transcript">{{ report.final_decision_full | e }}</div>
    <span class="collapse-link" onclick="collapseAndScroll(this)">Collapse full transcript</span>
  </details>
  {% endif %}

  <hr>

  {# ── I. Analyst Reports ───────────────────────────────────────────── #}
  <h2>I. Analyst Reports</h2>
  {% for section in report.analyst_sections %}
    <h3>{{ section.title }}</h3>
    {{ render_section(section) }}
  {% endfor %}

  {# ── II. Investment Research ──────────────────────────────────────── #}
  <h2>II. Investment Research</h2>

  <h3>{{ report.bull_history.title }}</h3>
  {{ render_section(report.bull_history) }}

  <h3>{{ report.bear_history.title }}</h3>
  {{ render_section(report.bear_history) }}

  <h3>{{ report.research_manager.title }}</h3>
  {{ render_section(report.research_manager) }}

  {# ── III. Trading Plan ────────────────────────────────────────────── #}
  <h2>III. Trading Plan</h2>

  <h3>{{ report.trader_plan.title }}</h3>
  {{ render_section(report.trader_plan) }}

  {# ── IV. Risk Management ──────────────────────────────────────────── #}
  <h2>IV. Risk Management</h2>

  <h3>{{ report.aggressive_history.title }}</h3>
  {{ render_section(report.aggressive_history) }}

  <h3>{{ report.conservative_history.title }}</h3>
  {{ render_section(report.conservative_history) }}

  <h3>{{ report.neutral_history.title }}</h3>
  {{ render_section(report.neutral_history) }}

  {# ── V. Final Decision ────────────────────────────────────────────── #}
  <h2>V. Final Decision</h2>

  <h3>{{ report.portfolio_manager.title }}</h3>
  {{ render_section(report.portfolio_manager) }}

</body>
</html>
